     m_executionDelay 15
     m_messageBody "Go out into the world, search the marked AOIs for caches, and avoid the insurgency as they attempt to deplete US forces down to nothing."\
     ""\
     "There are 5 caches in total."\
     "Good luck soldier!"
     m_factionKeys {
      "RHS_USAF"
     }
    }
   }
