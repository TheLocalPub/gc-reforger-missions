    TILW_SendMessageInstruction "{63090E96CF71DB89}" {
     m_messageTitle "Welcome"
     m_messageBody "Welcome to Cache Hunters"\
     "This mission has the ability to be played as a seeder or as a main mission which can seamlessly transition based on leadership and player count."
